{
	"name": "@screen-capture/node",
	"version": "1.0.0",
	"description": "Cross-platform native screen capture for Node.js on Windows and Linux/Wayland",
	"homepage": "https://github.com/tux-tn/node-screen-capture#readme",
	"author": "Sarhan Aissi <npm@tux.tn>",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"repository": {
		"url": "git+https://github.com/tux-tn/node-screen-capture.git",
		"type": "git"
	},
	"bugs": {
		"url": "https://github.com/tux-tn/node-screen-capture/issues"
	},
	"license": "MIT",
	"keywords": [
		"screen-capture",
		"screenshot",
		"wayland",
		"pipewire",
		"windows",
		"desktop-duplication",
		"dxgi",
		"graphics-capture",
		"napi-rs",
		"node-addon"
	],
	"files": [
		"dist",
		"index.js",
		"index.d.ts",
		"LICENSE",
		"README.md"
	],
	"napi": {
		"binaryName": "screen_capture",
		"packageName": "@screen-capture/node",
		"targets": [
			"x86_64-pc-windows-msvc",
			"i686-pc-windows-msvc",
			"aarch64-pc-windows-msvc",
			"x86_64-unknown-linux-gnu",
			"aarch64-unknown-linux-gnu"
		]
	},
	"engines": {
		"node": ">=23.5.0 || ^22.13.0 || ^20.17.0"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"scripts": {
		"artifacts": "napi artifacts",
		"build": "tsdown",
		"build:addon": "napi build --platform --release --esm",
		"build:addon:debug": "napi build --platform",
		"changelog": "conventional-changelog -p conventionalcommits",
		"format": "oxfmt --check",
		"format:fix": "oxfmt",
		"format:rust": "cargo fmt",
		"format:toml": "taplo format",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"prepublishOnly": "pnpm build && napi prepublish --skip-optional-publish -t npm",
		"test": "vitest run test/unit",
		"test:coverage": "vitest run --coverage",
		"test:capture": "node scripts/capture-smoke.js",
		"test:e2e": "vitest run test/integration",
		"test:watch": "vitest",
		"version": "napi version"
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.7.3",
		"@taplo/cli": "^0.7.0",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"conventional-changelog": "^8.1.0",
		"conventional-changelog-conventionalcommits": "^10.2.1",
		"oxfmt": "0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"tsdown": "^0.22.5",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"type": "module",
	"packageManager": "pnpm@11.11.0"
}
