{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2024"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": false,
		"outDir": "./dist",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": ["src/**/*.ts"]
}
